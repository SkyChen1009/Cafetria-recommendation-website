const APP_CONFIG = {
  mapLanguage: "zh-TW",
  mapRegion: "TW",
  fallbackCenter: { lat: 25.033968, lng: 121.564468 },
  searchRadiusMeters: 5000,
  movementThresholdMeters: 250,
  detailsConcurrency: 4,
};

const state = {
  map: null,
  infoWindow: null,
  markers: [],
  lastSearchCenter: null,
  pendingSearchCenter: null,
  searchInProgress: false,
  suppressNextIdle: false,
  searchToken: 0,
};

const dom = {
  locateMeButton: document.getElementById("locate-me"),
  resultCount: document.getElementById("result-count"),
  results: document.getElementById("results"),
  searchAreaButton: document.getElementById("search-this-area"),
  statusMessage: document.getElementById("status-message"),
  statusTitle: document.getElementById("status-title"),
  summaryCenter: document.getElementById("summary-center"),
  summaryMode: document.getElementById("summary-mode"),
};

document.addEventListener("DOMContentLoaded", () => {
  void initialize();
});

async function initialize() {
  attachEvents();
  setStatus("載入地圖中", "準備初始化 Google Maps 與咖啡廳搜尋");

  try {
    await loadGoogleMapsScript(getGoogleMapsApiKey());
    await initializeMap();

    const center = await resolveInitialCenter();
    state.map.setCenter(center);
    state.map.setZoom(14);
    await runSearch(center, "已依目前位置搜尋 5 公里內咖啡廳");
  } catch (error) {
    console.error(error);
    const message = extractErrorMessage(error);
    setStatus("初始化失敗", message);
    setSummaryMode("初始化失敗");
    renderEmptyState("地圖初始化失敗", message);
  }
}

function attachEvents() {
  dom.locateMeButton.addEventListener("click", async () => {
    try {
      setStatus("重新定位中", "準備回到目前位置");
      const center = await getUserLocation();
      state.suppressNextIdle = true;
      state.map.panTo(center);
      state.map.setZoom(14);
      await runSearch(center, "已回到目前位置並重新搜尋");
    } catch (error) {
      setStatus("重新定位失敗", extractErrorMessage(error));
    }
  });

  dom.searchAreaButton.addEventListener("click", async () => {
    if (!state.pendingSearchCenter) {
      return;
    }

    await runSearch(state.pendingSearchCenter, "已依目前地圖中心重新搜尋");
  });
}

async function initializeMap() {
  const { Map, InfoWindow } = await google.maps.importLibrary("maps");

  state.map = new Map(document.getElementById("map"), {
    center: APP_CONFIG.fallbackCenter,
    zoom: 13,
    clickableIcons: false,
    fullscreenControl: false,
    mapTypeControl: false,
    streetViewControl: false,
    styles: [
      {
        featureType: "poi.business",
        stylers: [{ visibility: "off" }],
      },
    ],
  });

  state.infoWindow = new InfoWindow();
  state.map.addListener("idle", handleMapIdle);
}

function handleMapIdle() {
  if (state.suppressNextIdle) {
    state.suppressNextIdle = false;
    return;
  }

  if (!state.lastSearchCenter) {
    return;
  }

  const center = state.map.getCenter();
  if (!center) {
    return;
  }

  const centerLiteral = { lat: center.lat(), lng: center.lng() };
  const movedDistance = distanceMeters(centerLiteral, state.lastSearchCenter);

  if (movedDistance >= APP_CONFIG.movementThresholdMeters) {
    state.pendingSearchCenter = centerLiteral;
    dom.searchAreaButton.classList.remove("hidden");
    dom.searchAreaButton.textContent = "搜尋這個區域";
  } else {
    state.pendingSearchCenter = null;
    dom.searchAreaButton.classList.add("hidden");
  }
}

async function resolveInitialCenter() {
  const queryCenter = getQueryCenter();
  if (queryCenter) {
    return queryCenter;
  }

  try {
    return await getUserLocation();
  } catch (error) {
    setStatus(
      "定位未授權，改用展示位置",
      `${extractErrorMessage(error)}，已改用台北 101 周邊作為展示搜尋中心。`
    );
    return APP_CONFIG.fallbackCenter;
  }
}

async function runSearch(center, statusText) {
  if (state.searchInProgress) {
    return;
  }

  const token = ++state.searchToken;
  state.searchInProgress = true;
  state.pendingSearchCenter = null;
  dom.searchAreaButton.classList.add("hidden");
  dom.searchAreaButton.textContent = "搜尋中...";
  dom.resultCount.textContent = "搜尋中";
  dom.summaryCenter.textContent = formatCoordinate(center);
  renderLoadingState();
  setStatus("搜尋咖啡廳中", statusText);

  try {
    const result = await resolveCafeResults(center, token);
    if (token !== state.searchToken) {
      return;
    }

    const sortedPlaces = result.places.sort(comparePlaces);
    state.lastSearchCenter = center;
    setSummaryMode(result.modeLabel);
    renderMarkers(sortedPlaces);
    renderResults(sortedPlaces);
    setStatus("搜尋完成", result.note);
  } catch (error) {
    console.error(error);
    const message = extractErrorMessage(error);
    setSummaryMode("搜尋失敗");
    renderMarkers([]);
    renderEmptyState("無法取得附近咖啡廳", message);
    setStatus("搜尋失敗", message);
  } finally {
    if (token === state.searchToken) {
      state.searchInProgress = false;
      dom.searchAreaButton.textContent = "搜尋這個區域";
    }
  }
}

async function resolveCafeResults(center, token) {
  try {
    const livePlaces = await fetchNearbyCafes(center, token);
    if (livePlaces.length) {
      return {
        places: livePlaces,
        modeLabel: "Google Places 即時資料",
        note: `已整理 ${livePlaces.length} 間咖啡廳，依評分與評論數排序。`,
      };
    }

    return {
      places: buildDemoPlaces(center),
      modeLabel: "示範資料模式",
      note: "Google Places 沒有回傳可用咖啡廳，已改用示範資料避免清單為空。",
    };
  } catch (error) {
    console.warn("Live Places request failed. Falling back to demo data.", error);
    const reason = extractErrorMessage(error);
    return {
      places: buildDemoPlaces(center),
      modeLabel: "示範資料模式",
      note: `Google Places 搜尋失敗：${reason}。已改用示範資料供介面驗收。`,
    };
  }
}

async function fetchNearbyCafes(center, token) {
  const { PlacesService, PlacesServiceStatus } = await google.maps.importLibrary("places");
  const service = new PlacesService(state.map);
  const nearbyResults = await nearbySearchAllPages(service, center, PlacesServiceStatus);

  const deduped = new Map();
  for (const place of nearbyResults) {
    if (!place.place_id || !place.geometry?.location) {
      continue;
    }

    const location = toLatLngLiteral(place.geometry.location);
    if (distanceMeters(center, location) > APP_CONFIG.searchRadiusMeters) {
      continue;
    }

    if (!deduped.has(place.place_id)) {
      deduped.set(place.place_id, place);
    }
  }

  const queue = Array.from(deduped.values());
  const detailed = [];
  const workers = Array.from({ length: APP_CONFIG.detailsConcurrency }, async () => {
    while (queue.length > 0) {
      const place = queue.shift();
      if (!place) {
        return;
      }

      if (token !== state.searchToken) {
        return;
      }

      try {
        const detail = await getPlaceDetails(service, place.place_id, PlacesServiceStatus);
        detailed.push(normalizeLivePlace(detail));
      } catch (error) {
        console.warn("Place details request failed for", place.place_id, error);
        detailed.push(normalizeLivePlace(place));
      }
    }
  });

  await Promise.all(workers);
  return detailed;
}

function nearbySearchAllPages(service, center, PlacesServiceStatus) {
  return new Promise((resolve, reject) => {
    const allResults = [];

    service.nearbySearch(
      {
        location: center,
        radius: APP_CONFIG.searchRadiusMeters,
        type: "cafe",
      },
      function handlePage(results, status, pagination) {
        if (status === PlacesServiceStatus.ZERO_RESULTS) {
          resolve(allResults);
          return;
        }

        if (status !== PlacesServiceStatus.OK || !results) {
          reject(new Error(`PlacesService nearbySearch failed: ${status}`));
          return;
        }

        allResults.push(...results);

        if (pagination?.hasNextPage) {
          window.setTimeout(() => pagination.nextPage(), 2000);
          return;
        }

        resolve(allResults);
      }
    );
  });
}

function getPlaceDetails(service, placeId, PlacesServiceStatus) {
  return new Promise((resolve, reject) => {
    service.getDetails(
      {
        placeId,
        fields: [
          "business_status",
          "formatted_address",
          "formatted_phone_number",
          "geometry",
          "international_phone_number",
          "name",
          "opening_hours",
          "place_id",
          "price_level",
          "rating",
          "reviews",
          "types",
          "url",
          "user_ratings_total",
          "website",
        ],
      },
      (place, status) => {
        if (status === PlacesServiceStatus.OK && place) {
          resolve(place);
          return;
        }

        reject(new Error(`PlacesService getDetails failed: ${status}`));
      }
    );
  });
}

function normalizeLivePlace(place) {
  return {
    id: place.place_id || `live-${Math.random().toString(36).slice(2, 9)}`,
    displayName: place.name || "未命名咖啡廳",
    formattedAddress: place.formatted_address || place.vicinity || "未提供地址",
    googleMapsURI: place.url || "",
    websiteURI: place.website || "",
    location: place.geometry?.location ? toLatLngLiteral(place.geometry.location) : null,
    rating: place.rating,
    userRatingCount: place.user_ratings_total,
    priceLevel: formatLegacyPriceLevel(place.price_level),
    primaryTypeDisplayName: formatLegacyTypes(place.types),
    regularOpeningHours: {
      weekdayDescriptions: place.opening_hours?.weekday_text || [],
    },
    nationalPhoneNumber: place.formatted_phone_number || "",
    internationalPhoneNumber: place.international_phone_number || "",
    businessStatus: place.business_status || "",
    editorialSummary: "Google Maps JavaScript PlacesService 未提供 editorial summary，已改列出 API 可取得的詳細資料。",
    reviews: normalizeReviews(place.reviews || []),
    source: "live",
  };
}

function normalizeReviews(reviews) {
  return reviews.slice(0, 3).map((review) => ({
    authorName: review.author_name || "Google Maps 使用者",
    authorUrl: review.author_url || "",
    rating: review.rating,
    relativeTime: review.relative_time_description || "時間未提供",
    text: review.text || "",
  }));
}


function renderResults(places) {
  dom.resultCount.textContent = `${places.length} 筆`;

  if (!places.length) {
    renderEmptyState("沒有找到咖啡廳", "請移動地圖後再按一次搜尋這個區域。");
    return;
  }

  dom.results.innerHTML = "";
  const fragment = document.createDocumentFragment();
  places.forEach((place, index) => {
    fragment.appendChild(createPlaceCard(place, index));
  });
  dom.results.appendChild(fragment);
}

function createPlaceCard(place, index) {
  const article = document.createElement("article");
  article.className = "place-card";

  article.innerHTML = `
    <div class="place-card__top">
      <div>
        <span class="place-rank">#${index + 1}</span>
        <h3>${escapeHtml(place.displayName)}</h3>
      </div>
      <div class="place-score">
        <strong>${formatRating(place.rating)}</strong>
        <span>${formatRatingCount(place.userRatingCount)}</span>
      </div>
    </div>
    <p class="place-type">${escapeHtml(place.primaryTypeDisplayName || "咖啡廳")}</p>
    <p class="place-address">${escapeHtml(place.formattedAddress || "未提供地址")}</p>
    <div class="chip-list">${renderFactChips(place)}</div>
    <div class="detail-grid">
      <div>
        <span>總覽</span>
        <p>${escapeHtml(place.editorialSummary || "未提供總覽")}</p>
      </div>
      <div>
        <span>營業資訊</span>
        <p>${escapeHtml(formatOpeningHours(place.regularOpeningHours))}</p>
      </div>
      <div>
        <span>電話</span>
        <p>${escapeHtml(place.nationalPhoneNumber || place.internationalPhoneNumber || "未提供電話")}</p>
      </div>
      <div>
        <span>菜單 / 網站</span>
        <p>${renderWebsiteLink(place)}</p>
      </div>
    </div>
    <div class="link-list">${renderActionLinks(place)}</div>
    <section class="reviews-block">
      <h4>評論前 3 則</h4>
      ${renderReviews(place.reviews || [])}
    </section>
    <div class="provider-list">${renderSource(place)}</div>
  `;

  article.addEventListener("click", () => {
    focusPlace(place);
  });

  return article;
}

function renderFactChips(place) {
  const chips = [];

  if (place.priceLevel) {
    chips.push(`<span>${escapeHtml(place.priceLevel)}</span>`);
  }
  if (place.businessStatus) {
    chips.push(`<span>${escapeHtml(place.businessStatus)}</span>`);
  }
  if (place.websiteURI) {
    chips.push("<span>提供網站</span>");
  }
  if (place.reviews?.length) {
    chips.push("<span>含評論</span>");
  }
  if (place.regularOpeningHours?.weekdayDescriptions?.length) {
    chips.push("<span>含營業時間</span>");
  }

  return chips.length ? chips.join("") : "<span>Google 未提供更多欄位</span>";
}

function renderWebsiteLink(place) {
  const href = place.websiteURI || place.googleMapsURI;
  if (!href) {
    return "Google Places 未提供網站欄位";
  }

  return `<a href="${escapeAttribute(href)}" target="_blank" rel="noreferrer">開啟網站或地圖頁</a>`;
}

function renderActionLinks(place) {
  const links = [];

  if (place.googleMapsURI) {
    links.push(`<a href="${escapeAttribute(place.googleMapsURI)}" target="_blank" rel="noreferrer">Google Maps</a>`);
  }
  if (place.websiteURI) {
    links.push(`<a href="${escapeAttribute(place.websiteURI)}" target="_blank" rel="noreferrer">網站</a>`);
  }

  return links.join("") || "<span>未提供可操作連結</span>";
}

function renderReviews(reviews) {
  if (!reviews.length) {
    return `
      <div class="review-card">
        <p>Google Places API 沒有回傳評論。</p>
      </div>
    `;
  }

  return reviews
    .slice(0, 3)
    .map((review) => {
      const author = review.authorUrl
        ? `<a href="${escapeAttribute(review.authorUrl)}" target="_blank" rel="noreferrer">${escapeHtml(review.authorName)}</a>`
        : escapeHtml(review.authorName);

      return `
        <article class="review-card">
          <div class="review-card__meta">
            <strong>${author}</strong>
            <span>${formatRating(review.rating)} ・ ${escapeHtml(review.relativeTime)}</span>
          </div>
          <p>${escapeHtml(review.text || "未提供評論內容")}</p>
        </article>
      `;
    })
    .join("");
}

function renderSource(place) {
  if (place.source === "demo") {
    return "資料來源：示範資料模式。這表示地圖可載入，但 Places API 沒有成功回應。";
  }

  return "資料來源：Google Maps Platform";
}

function renderMarkers(places) {
  for (const marker of state.markers) {
    marker.setMap(null);
  }

  state.markers = [];

  places.forEach((place, index) => {
    if (!place.location) {
      return;
    }

    const marker = new google.maps.Marker({
      map: state.map,
      position: place.location,
      title: place.displayName,
      label: index < 99 ? { text: String(index + 1), color: "#fffaf3", fontWeight: "700" } : undefined,
    });

    marker.addListener("click", () => focusPlace(place));
    state.markers.push(marker);
  });
}

function focusPlace(place) {
  if (!place.location) {
    return;
  }

  state.suppressNextIdle = true;
  state.map.panTo(place.location);
  state.infoWindow.setContent(`
    <div class="info-window">
      <strong>${escapeHtml(place.displayName)}</strong>
      <p>${escapeHtml(place.formattedAddress || "")}</p>
      <p>評分 ${formatRating(place.rating)} ｜ ${formatRatingCount(place.userRatingCount)}</p>
    </div>
  `);
  state.infoWindow.setPosition(place.location);
  state.infoWindow.open({ map: state.map });
}

function renderLoadingState() {
  dom.results.innerHTML = `
    <div class="empty-state">
      <h3>搜尋中</h3>
      <p>正在整理附近咖啡廳與詳細資料，請稍候。</p>
    </div>
  `;
}

function renderEmptyState(title, message) {
  dom.resultCount.textContent = "0 筆";
  dom.results.innerHTML = `
    <div class="empty-state">
      <h3>${escapeHtml(title)}</h3>
      <p>${escapeHtml(message)}</p>
    </div>
  `;
}

function setStatus(title, message) {
  dom.statusTitle.textContent = title;
  dom.statusMessage.textContent = message;
}

function setSummaryMode(text) {
  if (dom.summaryMode) {
    dom.summaryMode.textContent = text;
  }
}

function comparePlaces(a, b) {
  const ratingDiff = (b.rating || 0) - (a.rating || 0);
  if (ratingDiff !== 0) {
    return ratingDiff;
  }

  return (b.userRatingCount || 0) - (a.userRatingCount || 0);
}

function formatCoordinate(center) {
  return `${center.lat.toFixed(5)}, ${center.lng.toFixed(5)}`;
}

function formatOpeningHours(openingHours) {
  if (!openingHours?.weekdayDescriptions?.length) {
    return "未提供營業時間";
  }

  return openingHours.weekdayDescriptions.join(" / ");
}

function formatRating(rating) {
  if (typeof rating !== "number") {
    return "未評分";
  }

  return `${rating.toFixed(1)} ★`;
}

function formatRatingCount(count) {
  if (typeof count !== "number") {
    return "評論數未提供";
  }

  return `${count.toLocaleString("zh-TW")} 則評論`;
}

function formatLegacyPriceLevel(priceLevel) {
  const mapping = {
    0: "免費",
    1: "平價",
    2: "中價位",
    3: "高價位",
    4: "非常高價位",
  };

  return mapping[priceLevel] || "";
}

function formatLegacyTypes(types) {
  if (!Array.isArray(types) || !types.length) {
    return "咖啡廳";
  }

  if (types.includes("cafe")) {
    return "咖啡廳";
  }

  return types[0];
}

function toLatLngLiteral(location) {
  return {
    lat: typeof location.lat === "function" ? location.lat() : location.lat,
    lng: typeof location.lng === "function" ? location.lng() : location.lng,
  };
}

function distanceMeters(a, b) {
  const earthRadius = 6371000;
  const dLat = toRadians(b.lat - a.lat);
  const dLng = toRadians(b.lng - a.lng);
  const lat1 = toRadians(a.lat);
  const lat2 = toRadians(b.lat);
  const sinLat = Math.sin(dLat / 2);
  const sinLng = Math.sin(dLng / 2);
  const h = sinLat * sinLat + Math.cos(lat1) * Math.cos(lat2) * sinLng * sinLng;
  return 2 * earthRadius * Math.asin(Math.sqrt(h));
}

function offsetCoordinate(origin, eastMeters, northMeters) {
  const earthRadius = 6378137;
  const dLat = northMeters / earthRadius;
  const dLng = eastMeters / (earthRadius * Math.cos(toRadians(origin.lat)));

  return {
    lat: origin.lat + (dLat * 180) / Math.PI,
    lng: origin.lng + (dLng * 180) / Math.PI,
  };
}

function toRadians(value) {
  return (value * Math.PI) / 180;
}

function getQueryCenter() {
  const params = new URLSearchParams(window.location.search);
  const latParam = params.get("lat");
  const lngParam = params.get("lng");

  if (latParam === null || lngParam === null) {
    return null;
  }

  const lat = Number(latParam);
  const lng = Number(lngParam);

  if (Number.isFinite(lat) && Number.isFinite(lng)) {
    return { lat, lng };
  }

  return null;
}

function getUserLocation() {
  return new Promise((resolve, reject) => {
    if (!navigator.geolocation) {
      reject(new Error("這個瀏覽器不支援地理定位。"));
      return;
    }

    navigator.geolocation.getCurrentPosition(
      (position) => {
        resolve({
          lat: position.coords.latitude,
          lng: position.coords.longitude,
        });
      },
      () => {
        reject(new Error("無法取得目前位置。"));
      },
      {
        enableHighAccuracy: true,
        timeout: 10000,
        maximumAge: 60000,
      }
    );
  });
}

function loadGoogleMapsScript() {
  if (window.google?.maps) {
    return Promise.resolve();
  }

  return new Promise((resolve, reject) => {
    const callbackName = "__initGoogleMapsCoffeeApp";
    window[callbackName] = () => {
      resolve();
      delete window[callbackName];
    };

    const script = document.createElement("script");
    script.src =
      "https://maps.googleapis.com/maps/api/js" +
      `?key=${encodeURIComponent(getGoogleMapsApiKey())}` +
      `&v=weekly&loading=async&libraries=places` +
      `&language=${encodeURIComponent(APP_CONFIG.mapLanguage)}` +
      `&region=${encodeURIComponent(APP_CONFIG.mapRegion)}` +
      `&callback=${callbackName}`;
    script.async = true;
    script.onerror = () => reject(new Error("Google Maps JavaScript API 載入失敗。"));
    document.head.appendChild(script);
  });
}

function getGoogleMapsApiKey() {
  const apiKey = window.RUNTIME_CONFIG?.googleMapsApiKey || "";

  if (!apiKey) {
    throw new Error(
      "找不到 Google Maps API key。請在專案根目錄建立 .env.local 並設定 GOOGLE_MAPS_API_KEY。"
    );
  }

  return apiKey;
}

function extractErrorMessage(error) {
  if (error instanceof Error && error.message) {
    return error.message;
  }

  return "發生未預期錯誤。";
}

function escapeHtml(value) {
  return String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

function escapeAttribute(value) {
  return escapeHtml(value);
}

